    "import pandas as pd\n",
    "from sqlalchemy import create_engine, text\n",
    "import os\n",
    "\n",
    "print(\"=\" * 80)\n",
    "print(\"LOADING CONTOSO DATA\")\n",
    "print(\"=\" * 80)\n",
    "\n",
    "# -------------------------------\n",
    "# DB CONFIG\n",
    "# -------------------------------\n",
    "DB_USER = \"\your name"\n"
    "DB_PASSWORD = \"your password\"\n",
    "DB_HOST = \"localhost\"\n",
    "DB_PORT = \"your port\"\n",
    "DB_NAME = \"contoso\"\n",
    "\n",
    "connection_string = (\n",
    "    f\"postgresql+psycopg2://{DB_USER}:{DB_PASSWORD}\"\n",
    "    f\"@{DB_HOST}:{DB_PORT}/{DB_NAME}\"\n",
    ")\n",
    "\n",
    "# -------------------------------\n",
    "# CONNECT TO DB (REAL CHECK)\n",
    "# -------------------------------\n",
    "try:\n",
    "    engine = create_engine(connection_string)\n",
    "\n",
    "    # actual connection test (not just engine creation)\n",
    "    with engine.connect() as conn:\n",
    "        conn.execute(text(\"SELECT 1\"))\n",
    "\n",
    "    print(\"\\n✓ Connected to PostgreSQL!\")\n",
    "\n",
    "except Exception as e:\n",
    "    print(f\"\\n✗ Connection failed: {e}\")\n",
    "    exit()\n",
    "\n",
    "# -------------------------------\n",
    "# FILE CONFIG\n",
    "# -------------------------------\n",
    "BASE_DIR = os.getcwd()\n",
    "\n",
    "files = {\n",
    "    'sales': '/Users/yashmalviya/contoso-retail-analysis/Sales.csv',\n",
    "    'customer': '/Users/yashmalviya/contoso-retail-analysis/Customer.csv',\n",
    "    'product': '/Users/yashmalviya/contoso-retail-analysis/Product.csv',\n",
    "    'date': '/Users/yashmalviya/contoso-retail-analysis/Date.csv',\n",
    "    'store': '/Users/yashmalviya/contoso-retail-analysis/Store.csv',\n",
    "    'currency': '/Users/yashmalviya/contoso-retail-analysis/Currency.csv'\n",
    "}\n",
    "\n",
    "print(\"\\nLoading CSV files...\")\n",
    "print(\"-\" * 80)\n",
    "\n",
    "# -------------------------------\n",
    "# LOAD DATA\n",
    "# -------------------------------\n",
    "for table_name, filename in files.items():\n",
    "    filepath = os.path.join(BASE_DIR, filename)\n",
    "\n",
    "    try:\n",
    "        if not os.path.exists(filepath):\n",
    "            print(f\"✗ {table_name.upper():<12} | File not found\")\n",
    "            continue\n",
    "\n",
    "        df = pd.read_csv(filepath)\n",
    "\n",
    "        # normalize column names\n",
    "        df.columns = [col.strip().lower().replace(\" \", \"_\") for col in df.columns]\n",
    "\n",
    "        # load in chunks (safe for large data)\n",
    "        df.to_sql(\n",
    "            table_name,\n",
    "            engine,\n",
    "            if_exists='replace',\n",
    "            index=False,\n",
    "            chunksize=5000,\n",
    "            method='multi'\n",
    "        )\n",
    "\n",
    "        print(f\"✓ {table_name.upper():<12} | {df.shape[0]:>10,} rows\")\n",
    "\n",
    "    except Exception as e:\n",
    "        print(f\"✗ {table_name.upper():<12} | ERROR → {e}\")\n",
    "\n",
    "print(\"-\" * 80)\n",
    "print(\"\\n✓ Data loading process completed!\")"
   ]
  }
 ],
